@model List<okumatakibisanalkutuphane.Models.Book>
@{
    ViewData["Title"] = "Dashboard";
    var goals = ViewBag.Goals as List<okumatakibisanalkutuphane.Models.Goal>;
}

<div class="row align-items-center mb-5">
    <div class="col-md-8">
        <h1 class="display-5 fw-bold mb-1">Merhaba, <span class="text-gradient">@ViewBag.UserName</span> 👋</h1>
        <p class="text-muted fs-5">Okuma serüveninde bugün neler var? İşte istatistiklerin.</p>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
        <div class="dropdown d-inline-block">
            <button class="btn btn-primary dropdown-toggle shadow-sm" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-download me-2"></i>Rapor İndir
            </button>
            <ul class="dropdown-menu dropdown-menu-end glass border-0 shadow">
                <li><a class="dropdown-item" asp-controller="Books" asp-action="ExportExcel"><i class="bi bi-file-earmark-excel me-2 text-success"></i>Excel Olarak İndir</a></li>
                <li><a class="dropdown-item" asp-controller="Books" asp-action="ExportPdf"><i class="bi bi-file-earmark-pdf me-2 text-danger"></i>PDF Olarak İndir</a></li>
            </ul>
        </div>
    </div>
</div>

<!-- Stats Grid -->
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card stat-card p-4 border-0 shadow-sm">
            <div class="d-flex align-items-center">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                    <i class="bi bi-journal-text fs-3 text-primary"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-0">Toplam Kitap</h6>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalBooks</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card p-4 border-0 shadow-sm">
            <div class="d-flex align-items-center">
                <div class="rounded-circle bg-success bg-opacity-10 p-3 me-3">
                    <i class="bi bi-check2-all fs-3 text-success"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-0">Biten Kitaplar</h6>
                    <h3 class="fw-bold mb-0">@ViewBag.FinishedBooks</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card p-4 border-0 shadow-sm">
            <div class="d-flex align-items-center">
                <div class="rounded-circle bg-info bg-opacity-10 p-3 me-3">
                    <i class="bi bi-book fs-3 text-info"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-0">Okunanlar</h6>
                    <h3 class="fw-bold mb-0">@ViewBag.ReadingBooks</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card p-4 border-0 shadow-sm">
            <div class="d-flex align-items-center">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3 me-3">
                    <i class="bi bi-lightning-charge fs-3 text-warning"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-0">Haftalık Sayfa</h6>
                    <h3 class="fw-bold mb-0">@(((List<int>)ViewBag.Last7DaysData).Sum())</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Chart Section -->
    <div class="col-lg-8">
        <div class="card p-4 border-0 shadow-sm h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Haftalık Performans</h5>
                <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">Son 7 Gün</span>
            </div>
            <div style="position: relative; height: 300px; width: 100%;">
                <canvas id="readingChart"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Goals Section -->
    <div class="col-lg-4">
        <div class="card p-4 border-0 shadow-sm h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Hedeflerin</h5>
                <button class="btn btn-sm btn-outline-primary rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#addGoalModal">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </div>
            
            @if (goals != null && goals.Any())
            {
                foreach (var goal in goals)
                {
                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="fw-semibold">@goal.Title</span>
                            <span class="text-muted small">@goal.CurrentProgress / @goal.TargetPages sayfa</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar" role="progressbar" style="width: @goal.ProgressPercentage%" aria-valuenow="@goal.ProgressPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <div class="d-flex justify-content-between mt-1">
                            <small class="text-muted">@goal.EndDate.ToString("dd MMM") sona eriyor</small>
                            <small class="fw-bold text-primary">%@goal.ProgressPercentage</small>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-flag text-muted display-4"></i>
                    <p class="text-muted mt-3">Henüz bir hedef belirlemedin.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Active Books -->
<div class="card border-0 shadow-sm p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold mb-0">Okumaya Devam Et</h5>
        <a asp-controller="Books" asp-action="Index" class="btn btn-link text-decoration-none fw-semibold">Tüm Kütüphane <i class="bi bi-arrow-right ms-1"></i></a>
    </div>
    <div class="row g-4">
        @foreach (var book in Model.Where(b => b.Status == "Reading").Take(3))
        {
            <div class="col-md-4">
                <div class="card h-100 border-0 bg-light bg-opacity-50 p-3 hover-lift">
                    <div class="d-flex align-items-center">
                        <img src="@(string.IsNullOrEmpty(book.ImageUrl) ? "https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&fit=crop&q=80&w=200" : book.ImageUrl)" class="rounded shadow-sm me-3" style="width: 60px; height: 90px; object-fit: cover;" />
                        <div class="flex-grow-1 overflow-hidden">
                            <h6 class="fw-bold text-truncate mb-1">@book.Title</h6>
                            <p class="text-muted small mb-2 text-truncate">@book.Author</p>
                            <div class="progress mb-1" style="height: 4px;">
                                <div class="progress-bar" style="width: @book.ProgressPercentage%"></div>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small class="text-muted">%@book.ProgressPercentage</small>
                                <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="small fw-bold text-primary text-decoration-none">Devam Et</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Add Goal Modal -->
<div class="modal fade" id="addGoalModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Yeni Hedef Oluştur</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Reading" asp-action="CreateGoal" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Hedef Başlığı</label>
                        <input type="text" name="Title" class="form-control rounded-3" placeholder="Örn: Yaz Okuma Maratonu" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hedef Sayfa Sayısı</label>
                        <input type="number" name="TargetPages" class="form-control rounded-3" placeholder="Örn: 1000" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Başlangıç</label>
                            <input type="date" name="StartDate" class="form-control rounded-3" value="@DateTime.Today.ToString("yyyy-MM-dd")" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Bitiş</label>
                            <input type="date" name="EndDate" class="form-control rounded-3" value="@DateTime.Today.AddMonths(1).ToString("yyyy-MM-dd")" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow">Hedefi Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const colors = getChartColors();
            const ctxLine = document.getElementById('readingChart').getContext('2d');
            
            new Chart(ctxLine, {
                type: 'line',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.Last7DaysLabels)),
                    datasets: [{
                        label: 'Okunan Sayfa',
                        data: @Html.Raw(Json.Serialize(ViewBag.Last7DaysData)),
                        borderColor: colors.primary,
                        backgroundColor: colors.primary + '20',
                        borderWidth: 4,
                        pointBackgroundColor: colors.primary,
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointRadius: 6,
                        pointHoverRadius: 8,
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: colors.text,
                            titleColor: '#fff',
                            bodyColor: '#fff',
                            padding: 12,
                            cornerRadius: 8,
                            displayColors: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: colors.grid },
                            ticks: { color: colors.text + '80', font: { family: 'Outfit' } }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: colors.text + '80', font: { family: 'Outfit' } }
                        }
                    }
                }
            });
        });
    </script>
}

<style>
    .hover-lift {
        transition: var(--transition);
        cursor: pointer;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        background-color: var(--surface) !important;
        box-shadow: var(--shadow) !important;
    }
</style>
