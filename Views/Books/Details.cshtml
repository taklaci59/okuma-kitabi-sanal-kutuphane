@model okumatakibisanalkutuphane.Models.Book
@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-link text-decoration-none p-0 text-muted">
        <i class="bi bi-arrow-left me-1"></i>Kütüphaneye Dön
    </a>
</div>

<div class="row g-4">
    <!-- Left: Book Info -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm overflow-hidden mb-4">
            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&fit=crop&q=80&w=400" : Model.ImageUrl)" class="card-img-top" style="height: 450px; object-fit: cover;" alt="@Model.Title">
            <div class="card-body p-4">
                <h3 class="fw-bold mb-1">@Model.Title</h3>
                <p class="text-muted fs-5 mb-3">@Model.Author</p>
                <div class="d-flex flex-wrap gap-2 mb-4">
                    <span class="badge bg-primary bg-opacity-10 text-primary px-3">@Model.Genre</span>
                    <span class="badge bg-secondary bg-opacity-10 text-muted px-3">@Model.TotalPages Sayfa</span>
                </div>
                
                <div class="d-grid gap-2">
                    <button class="btn btn-primary rounded-pill py-2 shadow" data-bs-toggle="modal" data-bs-target="#logSessionModal">
                        <i class="bi bi-plus-circle me-2"></i>Okuma Oturumu Ekle
                    </button>
                    <div class="row g-2">
                        <div class="col-6">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm w-100 rounded-pill">Düzenle</a>
                        </div>
                        <div class="col-6">
                            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bu kitabı silmek istediğine emin misin?')">
                                <button type="submit" class="btn btn-outline-danger btn-sm w-100 rounded-pill">Sil</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Progress & History -->
    <div class="col-lg-8">
        <!-- Progress Card -->
        <div class="card border-0 shadow-sm p-4 mb-4">
            <h5 class="fw-bold mb-4">İlerleme Durumu</h5>
            <div class="row align-items-center">
                <div class="col-md-3 text-center">
                    <div class="display-4 fw-bold text-primary">%@Model.ProgressPercentage</div>
                    <small class="text-muted">Tamamlandı</small>
                </div>
                <div class="col-md-9">
                    <div class="progress mb-2" style="height: 12px;">
                        <div class="progress-bar" role="progressbar" style="width: @Model.ProgressPercentage%"></div>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>@Model.CurrentPage sayfa okundu</span>
                        <span class="text-muted">@(Model.TotalPages - Model.CurrentPage) sayfa kaldı</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- History Card -->
        <div class="card border-0 shadow-sm p-4">
            <h5 class="fw-bold mb-4">Okuma Geçmişi</h5>
            @if (Model.Sessions != null && Model.Sessions.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Tarih</th>
                                <th>Aralık</th>
                                <th>Okunan</th>
                                <th>Süre (Dk)</th>
                                <th>Hız</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var session in Model.Sessions.OrderByDescending(s => s.Date))
                            {
                                <tr>
                                    <td>@session.Date.ToString("dd MMM yyyy")</td>
                                    <td>@session.StartPage - @session.EndPage</td>
                                    <td><span class="badge bg-success bg-opacity-10 text-success">@session.PagesRead sayfa</span></td>
                                    <td>@session.DurationMinutes dk</td>
                                    <td>@(session.DurationMinutes > 0 ? Math.Round((double)session.PagesRead / session.DurationMinutes, 2) : 0) s/dk</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-calendar-x text-muted display-4"></i>
                    <p class="text-muted mt-3">Henüz bir okuma oturumu kaydedilmemiş.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Log Session Modal -->
<div class="modal fade" id="logSessionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Okuma Oturumu Kaydet</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Reading" asp-action="LogSession" method="post">
                <input type="hidden" name="bookId" value="@Model.Id" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Kaldığın Sayfa</label>
                            <input type="number" name="startPage" class="form-control rounded-3" value="@Model.CurrentPage" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ulaştığın Sayfa</label>
                            <input type="number" name="endPage" class="form-control rounded-3" min="@Model.CurrentPage" max="@Model.TotalPages" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Süre (Dakika)</label>
                            <input type="number" name="duration" class="form-control rounded-3" placeholder="Kaç dakika okudun?" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow">Oturumu Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>
