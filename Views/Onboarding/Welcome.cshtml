@{
    Layout = "_Layout";
    ViewData["Title"] = "Hoş Geldiniz";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-6">
        <div class="card border-0 shadow-lg p-5 text-center glass">
            <div class="mb-4">
                <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex p-4">
                    <i class="bi bi-rocket-takeoff text-primary display-4"></i>
                </div>
            </div>
            <h1 class="fw-bold mb-3">LibrisTrack <span class="text-gradient">Pro</span>'ya Hoş Geldin!</h1>
            <p class="text-muted mb-4 fs-5">Okuma yolculuğuna başlamadan önce seni biraz tanıyalım.</p>
            
            <form asp-action="Welcome" method="post" class="text-start">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Adın Nedir?</label>
                    <input type="text" name="name" class="form-control rounded-3 py-2" placeholder="Örn: Kıvanç" required>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold">Aylık Okuma Hedefin (Sayfa)</label>
                    <input type="number" name="monthlyGoal" class="form-control rounded-3 py-2" placeholder="Örn: 500" required>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary py-3 rounded-pill fw-bold shadow">
                        Macerayı Başlat <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
